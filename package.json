{
  "name": "surgery-data-manager",
  "version": "0.3.0",
  "description": "手術データ管理アプリ — 記録媒体からの差分インポートとDICOM送信",
  "main": "electron/main.js",
  "private": true,
  "author": "Stella Animal Hospital",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build:mac": "electron-builder --mac --arm64 --x64",
    "build:mac:arm64": "electron-builder --mac --arm64",
    "build:mac:x64": "electron-builder --mac --x64",
    "rebuild": "electron-rebuild"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@electron/rebuild": "^3.6.0",
    "electron": "33.4.11",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "dcmjs-dimse": "^0.3.3",
    "electron-store": "^8.2.0",
    "heic-convert": "^2.1.0",
    "sanitize-filename": "^1.6.3",
    "wanakana": "^5.3.1"
  },
  "build": {
    "appId": "jp.stella-vet.surgery-data-manager",
    "productName": "Surgery Data Manager",
    "directories": {
      "output": "/Users/macbookns/Build/SurgeryDataManager",
      "buildResources": "electron/build"
    },
    "afterSign": "electron/notarize.js",
    "files": [
      "electron/**/*",
      "www/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.medical",
      "artifactName": "SurgeryDataManager-${version}-${arch}.${ext}",
      "icon": "electron/build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "minimumSystemVersion": "11.0",
      "entitlements": "electron/build/entitlements.mac.plist",
      "entitlementsInherit": "electron/build/entitlements.mac.plist"
    },
    "dmg": {
      "writeUpdateInfo": false
    }
  }
}
